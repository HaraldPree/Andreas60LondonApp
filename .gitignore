# v1.22.0 — next-pwa generiert wieder Service-Worker-Artefakte in
# public/ (sw.js + workbox-*.js + fallback-*.js + Maps). Diese werden
# bei jedem Build neu erzeugt und gehören nicht in git.
# Der manuelle Kill-Switch-SW aus v1.21.3 wurde gelöscht — wird durch
# den next-pwa-Output ersetzt. User mit altem SW werden vom
# ServiceWorkerCleanup-Hook (mit Idempotenz-Flag) einmalig aufgeräumt.
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/fallback-*.js
public/fallback-*.js.map

