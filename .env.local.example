# =========================================
# ZUGRIFFS-SCHUTZ (PIN-Gate)
# =========================================
# 4-stelliger Code, ohne den niemand auf die App zugreifen kann.
# In Vercel als Environment Variable setzen, Code per WhatsApp an die
# Reisegruppe teilen. Beispiel: 2026 oder 0518 (Anreise-Datum).
APP_PIN=

# =========================================
# ANTHROPIC (AI-Reisebegleiter)
# =========================================
# Format: sk-ant-api03-...
# Erstellen: https://console.anthropic.com/settings/keys
# WICHTIG: Wir nutzen APP_ANTHROPIC_KEY (nicht ANTHROPIC_API_KEY), weil
# manche Dev-Setups (z.B. Claude Code CLI) ANTHROPIC_API_KEY global leer
# gesetzt haben – würde .env.local überschreiben.
APP_ANTHROPIC_KEY=

# Legacy-Fallback (wird auch noch erkannt):
# RCMK_ANTHROPIC_KEY=

# =========================================
# AVIATIONSTACK (Live-Flugstatus)
# =========================================
# OPTIONAL – ohne Key wird Flightradar24-Link als Fallback gezeigt
# Free Tier: 100 Req/Monat, Sign-up: https://aviationstack.com/signup/free
AVIATIONSTACK_API_KEY=

# =========================================
# KOSTENFREIE APIs (kein Key nötig)
# =========================================
# Open-Meteo (Wetter), TfL (Tube), OpenStreetMap (Karten),
# Frankfurter (Wechselkurse) – alle ohne Authentifizierung.
