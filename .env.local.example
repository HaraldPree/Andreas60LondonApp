# Anthropic Claude API Key (für AI-Reisebegleiter)
# Erstelle einen Key auf https://console.anthropic.com/settings/keys
# Format: sk-ant-api03-...
#
# WICHTIG: Wir nutzen RCMK_ANTHROPIC_KEY (nicht ANTHROPIC_API_KEY), weil
# manche Entwicklungs-Setups (z.B. Claude Code CLI) ANTHROPIC_API_KEY global
# leer gesetzt haben – das würde .env.local überschreiben.
RCMK_ANTHROPIC_KEY=

# AviationStack API Key (für Live-Flugstatus)
# OPTIONAL – ohne Key wird Flightradar24-Link als Fallback gezeigt
# Free Tier: 100 Req/Monat, Sign-up: https://aviationstack.com/signup/free
# Server-seitiges Caching (5 min) reduziert Calls deutlich.
AVIATIONSTACK_API_KEY=

# Open-Meteo (Wetter), TfL (Tube), OpenStreetMap (Karten) sind kostenlos
# und benötigen keine Authentifizierung.
